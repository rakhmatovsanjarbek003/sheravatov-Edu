PORT=3000

# AI Configuration (Groq Multi-Keys Rotation)
# Agar bir nechta kalitingiz bo'lsa vergul bilan ajratib yozing: key1,key2,key3
GROQ_API_KEYS=gsk_your_key_1,gsk_your_key_2

# Telegram Cloud Storage Integration
# Bot orqali barcha media va fayllar saqlanadi
TELEGRAM_BOT_TOKEN=bot_token_here
TELEGRAM_STORAGE_CHAT_ID=-100_your_channel_or_chat_id
